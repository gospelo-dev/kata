{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Checklist",
  "description": "Structured checklist with categorized items and templates",
  "type": "object",
  "required": ["version", "description", "categories"],
  "properties": {
    "version": {
      "type": "string",
      "description": "Schema version"
    },
    "description": {
      "type": "string",
      "description": "Checklist description"
    },
    "categories": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "items"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "items": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["id", "name", "name_ja"],
              "properties": {
                "id": { "type": "string" },
                "name": { "type": "string" },
                "name_ja": { "type": "string" },
                "test_basis": { "type": "string" },
                "target": { "type": "string" },
                "requirements": { "type": "string" },
                "template": { "type": "string" },
                "tags": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "status": {
                  "type": "string",
                  "enum": ["draft", "pending", "approve", "reject"]
                }
              }
            }
          }
        }
      }
    },
    "templates": {
      "type": "object",
      "x-kata-meta": true,
      "description": "Suite template mapping (not rendered in document)"
    }
  }
}
