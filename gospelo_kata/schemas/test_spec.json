{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Test Specification",
  "description": "Test case specification for test execution",
  "type": "object",
  "required": ["test_cases"],
  "properties": {
    "test_name": {
      "type": "string"
    },
    "test_id_prefix": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "test_cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["test_id", "category", "description", "expected_result"],
        "properties": {
          "test_id": {
            "type": "string",
            "minLength": 1
          },
          "category": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "expected_result": {
            "type": "string",
            "minLength": 1
          },
          "params": {
            "type": "object"
          },
          "tags": {
            "type": "array",
            "items": { "type": "string" }
          },
          "priority": {
            "type": "string",
            "enum": ["high", "medium", "low"]
          }
        }
      }
    }
  }
}
